# Agora Configuration
# Get these from your Agora Console: https://console.agora.io/
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
AGORA_API_KEY=your_agora_api_key_here
AGORA_API_SECRET=your_agora_api_secret_here

# ASR (Automatic Speech Recognition) Configuration
ASR_VENDOR=ares
ASR_LANGUAGE=en-US

# LLM (Large Language Model) Configuration
# For custom LLM endpoints (or use standard providers via URL)
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_VENDOR=openai
LLM_API_KEY=your_agora_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=You are a helpful chatbot. Keep answers short and concise. Only output plain text responses, without any markdown, HTML tags, or emojis. Do not include any formatting symbols. This is a voice-to-voice service. 

# TTS Configuration options
TTS_Microsoft_VENDOR=microsoft
TTS_Microsoft_API_KEY=your_tts_api_key_here
TTS_Microsoft_REGION=your_tts_region_here
TTS_Microsoft_VOICE=en-US-AriaNeural
TTS_Microsoft_SPEED=1.0

TTS_ElevenLabs_BASE_URL=wss://api.elevenlabs.io/v1
TTS_ElevenLabs_API_KEY=your_elevenlabs_api_key_here
TTS_ElevenLabs_VOICE_ID=cgSgspJ2msm6clMCkdW9
TTS_ElevenLabs_MODEL_ID=eleven_multilingual_v2

TTS_MINIMAX_API_KEY=your_minimax_api_key_here
TTS_MINIMAX_GROUP_ID=your_minimax_group_id_here
TTS_MINIMAX_VOICE_ID=English_PlayfulGirl

# Server Configuration
PORT=3000

# Authentication (HTTP Basic Auth)
# Leave blank to disable authentication (for local development)
# Set these credentials for production deployment
AUTH_USERNAME=your_username_here
AUTH_PASSWORD=your_secure_password_here

# Optional: Development Settings
NODE_ENV=development